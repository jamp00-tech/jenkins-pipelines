pipeline {
    agent any

    parameters {
        choice(
            name: 'BUILD_TOOL',
            choices: [
                'maven',
                'others'
            ],
            description: 'Build tool'
        )

        choice(
            name: 'REPO_NAME',
            choices: [
                'spring-boot-jwt-kafka',
                'python-binance-trading-bot'
            ],
            description: 'Repository to build'
        )

        string(
            name: 'BRANCH',
            defaultValue: 'main',
            description: 'Branch to build'
        )

        choice(
            name: 'GITHUB_ORG',
            choices: [
                'jamp00-tech',
                'jamp00'
            ],
            description: 'Repository Organization to build'
        )

        booleanParam(
            name: 'RUN_TESTS',
            defaultValue: true,
            description: 'Run unit tests'
        )

    }

    environment {
        GITHUB_BASE_URL = "https://github.com/${params.GITHUB_ORG}"
        OCIR_REGION = "sa-saopaulo-1.ocir.io"
        OCIR_NAMESPACE = "greg14puj5pf"
    }

    stages {
        stage('Prepare Repository URL') {
            steps {
                script {
                    env.REPO_URL = "${env.GITHUB_BASE_URL}/${params.REPO_NAME}.git"
                    echo "Repository URL: ${env.REPO_URL}"
                }
            }
        }

        stage('Clone Application Repository') {
            steps {
                dir('app-repo') {
                    git branch: params.BRANCH,
                        credentialsId: 'github-token',
                        url: env.REPO_URL
                }
            }
        }

        stage('Build Application') {
            steps {
                dir('app-repo') {
                    script {
                        if (params.BUILD_TOOL == 'maven') {
                            if (params.RUN_TESTS) {
                                sh 'mvn clean package'
                            } else {
                                sh 'mvn clean package -DskipTests'
                            }
                        }
                        if (params.BUILD_TOOL == 'others') {
                            echo "Skipping local build step"
                        }

                    }
                }
            }
        }

        stage('Build Docker Image') {
            steps {
                dir('app-repo') {
                    script {
                        def appVersion = ""
                        if (params.BUILD_TOOL == 'maven') {
                            appVersion = sh(
                                script: "mvn help:evaluate -Dexpression=project.version -q -DforceStdout",
                                returnStdout: true
                            ).trim()
                        }
                        if (params.BUILD_TOOL == 'others') {
                            appVersion = sh(
                                script: "grep '^release:' VERSION.yaml | awk '{print \$2}'",
                                returnStdout: true
                            ).trim()
                        }
                        currentBuild.displayName = "${params.REPO_NAME}:${appVersion}"
                        env.IMAGE_TAG = "${env.OCIR_REGION}/${env.OCIR_NAMESPACE}/${params.REPO_NAME}:${appVersion}"
        
                        echo "Docker image version: ${appVersion}"
                        echo "Full image tag: ${env.IMAGE_TAG}"
        
                        sh """
                            docker build -t ${env.IMAGE_TAG} .
                        """
                    }
                }
            }
        }

        stage('Push Docker Image to OCIR') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'ocir-credentials',
                    usernameVariable: 'OCIR_USER',
                    passwordVariable: 'OCIR_TOKEN'
                )]) {
                    sh """
                        echo "$OCIR_TOKEN" | docker login ${env.OCIR_REGION} -u "$OCIR_USER" --password-stdin
                        docker push ${env.IMAGE_TAG}
                        docker logout ${env.OCIR_REGION}
                    """
                }
            }
        }

        stage('Archive Artifact') {
            steps {
                script {
                    if (params.BUILD_TOOL == 'maven') {
                        archiveArtifacts artifacts: 'app-repo/**/target/*.jar', fingerprint: true
                    } else {
                        echo "Python app detected - no JAR artifact to archive"
                    }
                }
            }
        }
    }

    post {
        success {
            echo "Build completed successfully"
        }

        failure {
            echo "Build failed"
        }

        always {
            cleanWs()
        }
    }
}
